// Windows resource script for the Fluent-Qt Gallery executable.
// Generated from app.rc.in by CMake (configure_file, @ONLY) into the build tree.
// Do NOT edit the generated app.rc — edit this template instead.
// zh_CN: 这是 Gallery 可执行文件的 Windows 资源脚本，由 CMake configure_file 生成 app.rc。
// 请改本模板，不要改生成出来的 app.rc。

#include <windows.h>

// Application icon. The numerically lowest icon ID is the one Explorer, the taskbar,
// Alt-Tab and the installer-created shortcuts use as the app icon, so keep this at 1.
// The path is the absolute source .ico injected by CMake (forward slashes for rc.exe).
// zh_CN: 应用图标。ID 最小（这里为 1）的图标会被资源管理器/任务栏/Alt-Tab/快捷方式当作应用图标。
// 路径是 CMake 注入的源 .ico 绝对路径（用正斜杠，rc.exe 可识别）。
1 ICON "@FLUENT_QT_GALLERY_ICO@"

// File/Product version metadata shown in the exe's Properties > Details tab. Mirrors the
// macOS Info.plist (name, version) so both platforms report consistent identity.
// zh_CN: 版本元数据，显示在 exe 属性 > 详细信息里，与 macOS Info.plist 的名称/版本保持一致。
VS_VERSION_INFO VERSIONINFO
    FILEVERSION    @PROJECT_VERSION_MAJOR@,@PROJECT_VERSION_MINOR@,@PROJECT_VERSION_PATCH@,0
    PRODUCTVERSION @PROJECT_VERSION_MAJOR@,@PROJECT_VERSION_MINOR@,@PROJECT_VERSION_PATCH@,0
    FILEFLAGSMASK  VS_FFI_FILEFLAGSMASK
    FILEFLAGS      0x0L
    FILEOS         VOS_NT_WINDOWS32
    FILETYPE       VFT_APP
    FILESUBTYPE    VFT2_UNKNOWN
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        // 0409 = U.S. English, 04b0 = Unicode (1200) code page.
        BLOCK "040904b0"
        BEGIN
            VALUE "CompanyName",      "Fluent-Qt"
            VALUE "FileDescription",  "Fluent-Qt Gallery"
            VALUE "FileVersion",      "@PROJECT_VERSION@.0"
            VALUE "InternalName",     "fluent_qt_gallery"
            VALUE "LegalCopyright",   "Fluent-Qt"
            VALUE "OriginalFilename", "fluent_qt_gallery.exe"
            VALUE "ProductName",      "Fluent-Qt Gallery"
            VALUE "ProductVersion",   "@PROJECT_VERSION@"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x409, 1200
    END
END
